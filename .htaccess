# ── 디렉토리 목록 비활성화 ──────────────────────────────────────
Options -Indexes

# ── 민감 파일 · 숨김 파일 접근 차단 ─────────────────────────────
# Apache 2.4+: mod_authz_core / Apache 2.2: Order-Deny 방식 분기
<FilesMatch "(\.env.*|\.sh|\.gitignore)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# ── HTTP 보안 헤더 ────────────────────────────────────────────────
<IfModule mod_headers.c>
  # 클릭재킹 방지
  Header always set X-Frame-Options "SAMEORIGIN"

  # MIME 타입 스니핑 방지
  Header always set X-Content-Type-Options "nosniff"

  # XSS 필터 (구형 브라우저)
  Header always set X-XSS-Protection "1; mode=block"

  # 리퍼러 정책
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # 브라우저 권한 잠금
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # 콘텐츠 보안 정책
  # - script-src : GSAP(cdnjs), Lenis·EmailJS(jsdelivr)
  # - style-src  : Google Fonts + 인라인 스타일(HTML 속성)
  # - font-src   : Google Fonts 실제 파일
  # - connect-src: EmailJS API
  Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
font-src 'self' https://fonts.gstatic.com; \
img-src 'self' data:; \
connect-src 'self' https://api.emailjs.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; \
frame-ancestors 'none';"
</IfModule>
